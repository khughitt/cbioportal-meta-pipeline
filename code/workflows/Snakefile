#
# Clonal-hematopoiesis-aware annotation. Intermediate ratio output:
# `gene_cancer_study_ratio_ch_annotated.feather` — carries Bailey + CGC + pathway overlays (from
# the upstream unified rule) AND the CH annotations. The canonical ratio output is the
# downstream meta-joined `gene_cancer_study_ratio_annotated.feather`.
#
# Adds `ch_priority_gene` flag (Bolton 2020 7-gene list) plus `mean_matched` / `mean_unmatched`
# stratified ratios computed over per-study columns partitioned by the `matched_normal_studies`
# config list.
#
# Config: populate `matched_normal_studies` in the run config with an explicit list of study IDs
# known to use patient-matched buffy-coat / normal sequencing. Studies omitted are treated as
# tumor-only. If the key is missing, all studies default to tumor-only and `mean_matched` is NaN.
#
rule annotate_ch_in_gene_cancer_ratio_table:
  input:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio_overlay_annotated.feather")
  output:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio_ch_annotated.feather")
  script:
    "../scripts/annotate_ch.py"

