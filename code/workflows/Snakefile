    grid_meta = out_dir.joinpath("association/h08_association_grid.meta.json"),
    exposures = out_dir.joinpath("studies/tcga_mc3/mut/signatures/restricted_assignment_per_sample.feather")
  output:
    sensitivity = out_dir.joinpath("association/h08_sensitivity.feather"),
    permutation = out_dir.joinpath("association/h08_permutation_null.feather"),
    lung = out_dir.joinpath("association/h08_lung_pooling.feather"),
    meta = out_dir.joinpath("association/h08_sensitivity.meta.json")
  params:
    configfile = h08_configfile
  log:
    out_dir.joinpath("logs/run_h08_sensitivity.log")
  conda:
    "../envs/project-python.yml"
  shell:
    "python code/scripts/run_h08_sensitivity.py --config {params.configfile} > {log} 2>&1"

#
# t200 — read-only within-tissue failure diagnostics over the frozen h08 association artifacts.
# Reproduces the WP2 target fits, re-derives the broken smoking binary from raw PanCanAtlas labels,
# runs burden/proximal conditioning probes, and scores APOBEC proliferation robustness from full
# per-arm RSEM. Diagnostic only: the locked H08a verdict is not re-read by this rule.
#
rule diagnose_h08_within_tissue:
  input:
    covariates = out_dir.joinpath("association/h08_covariates.feather"),
