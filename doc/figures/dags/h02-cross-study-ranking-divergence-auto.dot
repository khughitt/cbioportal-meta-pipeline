// h02-cross-study-ranking-divergence — proposition DAG for hypothesis h02.
// Nodes are the ranking schemes + the gene-level confounders + the cross-study outcomes;
// edges are the P1-P4 propositions. Support/dispute evidence lives in the paired
// h02-cross-study-ranking-divergence.edges.yaml. Render: science dag render --dag h02-cross-study-ranking-divergence
digraph h02_cross_study_ranking_divergence {
  rankdir=TB;
  labelloc="t";
  label=<<b>h02 — cross-study ranking divergence is structured</b><br/><font point-size="9" color="#555"><i>auto-styled from edges.yaml — color=edge_status, width=|β|, style=HDI-crosses-zero-dashed, arrowhead=identification</i></font>>;
  node [shape=box, style="rounded,filled", fillcolor="#f0f0f0", fontsize=10];
  edge [fontsize=9];

  gene_length [label="Gene length /\nprotein size", fillcolor="#fef7e0"];
  cfs         [label="Common-fragile-site\ninstability", fillcolor="#fef7e0"];
  rep_timing  [label="Replication timing\n(late)", fillcolor="#fef7e0"];

  raw_rank    [label="Raw-frequency\nranking"];
  lenadj_rank [label="Length-adjusted\nranking"];
  dndscv_rank [label="dNdScv selection\nranking", fillcolor="#e8f0fe"];

  divergence  [label="Structured scheme\ndivergence (P3)", fillcolor="#e6f4ea"];
  drivers     [label="Canonical-driver\nrecovery (Bailey/CGC)", fillcolor="#e6f4ea"];
  longtail    [label="Long-tail\ncandidates"];
  stability   [label="Cross-study (LOSO)\nrank stability", fillcolor="#fce8e6"];

  gene_length -> raw_rank [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[1]", fontsize=10, fontcolor="#2e7d32"];
  gene_length -> lenadj_rank [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[2]", fontsize=10, fontcolor="#2e7d32"];
  gene_length -> dndscv_rank [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[3]", fontsize=10, fontcolor="#1565c0"];
  cfs -> raw_rank [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[4]", fontsize=10, fontcolor="#c62828"];
  cfs -> dndscv_rank [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[5]", fontsize=10, fontcolor="#c62828"];
  rep_timing -> dndscv_rank [color="#9e9e9e", penwidth=1.0, style="dotted", arrowhead=normal, label="[6] [✗]", fontsize=10, fontcolor="#9e9e9e"];
  raw_rank -> divergence [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[7]", fontsize=10, fontcolor="#2e7d32"];
  lenadj_rank -> divergence [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[8]", fontsize=10, fontcolor="#2e7d32"];
  divergence -> longtail [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[9]", fontsize=10, fontcolor="#1565c0"];
  dndscv_rank -> drivers [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[10]", fontsize=10, fontcolor="#2e7d32"];
  drivers -> stability [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[11]", fontsize=10, fontcolor="#1565c0"];
  longtail -> stability [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[12]", fontsize=10, fontcolor="#1565c0"];

  // --- Auto-footer legend (two-axis: edge_status + identification) ---
  subgraph cluster_auto_footer_legend {
    rank=sink;
    label="";
    color="#bdbdbd"; style="rounded"; margin=4;
    node [shape=plaintext, fontsize=9];
    footer_legend [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3" color="#bdbdbd">
      <tr><td bgcolor="#f5f5f5"><b>Auto legend</b></td><td bgcolor="#f5f5f5"><b>edge_status</b>: color / width / style</td><td bgcolor="#f5f5f5"><b>identification</b>: arrowhead</td></tr>
      <tr><td align="left">status</td><td align="left"><font color="#2e7d32">&#9473;&#9473;&#9654;</font> supported &nbsp; <font color="#1565c0">&#9472;&#9472;&#9654;</font> tentative &nbsp; <font color="#757575">&#8943;&#9654;</font> structural</td><td align="left"><font color="#2e7d32">&#9473;&#9473;&#9654;</font> normal: observational / structural / none</td></tr>
      <tr><td align="left"></td><td align="left"><font color="#c62828">&#9548;&#9548;&#9654;</font> unknown &nbsp; <font color="#9e9e9e">&#8943;&#9654;</font> [x] eliminated</td><td align="left"><font color="#2e7d32">&#9473;&#9473;&#9670;</font> interventional &nbsp; <font color="#2e7d32">&#9473;&#9473;&#8857;</font> longitudinal</td></tr>
    </table>>];
  }
}
