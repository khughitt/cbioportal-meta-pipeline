# Local convenience symlink so pyproject.toml's `../../science/science-tool`
# path resolves correctly from worktrees nested under .worktrees/.
/science

# Pipeline outputs / caches (not committed)
results/
# models/ holds both regenerable model dumps (ignored) and hand-authored causal-DAG
# sources (tracked, Science causal-modeling convention). Exclude contents, then
# re-include the DAGs + docs. Must be `models/*` not `models/`: git won't descend into
# a wholly-excluded dir, so negations under it would have no effect.
models/*
!models/README.md
!models/*.dot
.snakemake/
tasks/.tasks.lock
.venv/

