#
# cbioportal / pan-cancer meta-analysis
#
import pathlib

data_dir = pathlib.Path(config['data_dir'])
out_dir = pathlib.Path(config['out_dir'])

ids = config["studies"]

entities = ['cancer', 'cancer_detailed', 'gene']

rule all:
  input:
    expand(out_dir.joinpath("summary/mut/table/{entity}_study.feather"), entity=entities),
    expand(out_dir.joinpath("summary/mut/table/{entity}_study_ratio.feather"), entity=entities),
    expand(out_dir.joinpath("studies/{id}/mut/matrix/cancer_cor.feather"), id=ids),
    expand(out_dir.joinpath("studies/{id}/mut/matrix/gene_cor.feather"), id=ids),
    out_dir.joinpath("metadata/samples.feather"),
    out_dir.joinpath("metadata/studies.feather"),
    out_dir.joinpath("summary/mut/table/gene_cancer_study.feather"),
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio.feather"),
    out_dir.joinpath("summary/mut/matrix/gene_cancer.feather"),
    out_dir.joinpath("summary/mut/matrix/gene_cancer_ratio.feather"),
    out_dir.joinpath("summary/mut/matrix/gene_patient.feather"),
    out_dir.joinpath("summary/mut/clusters/cancer.feather"),
    out_dir.joinpath("summary/mut/clusters/gene.feather"),
    out_dir.joinpath("summary/mut/table/gene_cancer_study_annotated.feather"),
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio_annotated.feather"),
    out_dir.joinpath("summary/summary.html")

#
# Bailey 2018 driver-annotation overlay.
#
# Manual prerequisite: download Bailey et al. 2018 (Cell) supplementary Table S1 from
# the Cell article page (PMID 30096302 / DOI 10.1016/j.cell.2018.02.060) and place at
# data/bailey2018_table_s1.xlsx. Direct fetch is blocked by Cell's CDN; this is a one-time
# manual step.
#
rule process_bailey2018_drivers:
  input:
    "data/bailey2018_table_s1.tsv"
  output:
    out_dir.joinpath("metadata/bailey2018_drivers.feather")
  script:
    "../scripts/process_bailey2018_drivers.py"

#
# Sanchez-Vega 2018 curated oncogenic-pathway templates (10 canonical pathways).
# Source: Cell article S0092-8674(18)30359-3 supplementary Table S3.
# Manual prereq: `data/sanchez_vega_2018_tables_s3.xlsx`.
#
rule process_sanchez_vega_pathways:
  input:
    "data/sanchez_vega_2018_tables_s3.xlsx"
  output:
    out_dir.joinpath("metadata/sanchez_vega_pathways.feather")
  script:
    "../scripts/process_sanchez_vega_pathways.py"

#
# COSMIC Cancer Gene Census (CGC). Gene-level curated reference list (~750 genes at
# v100), Tier 1 + Tier 2 + role-in-cancer annotation.
#
# Manual prereq: CGC TSV from cancer.sanger.ac.uk/cosmic/download (free academic account).
# Config key `cosmic_cgc_path` defaults to `data/cancer_gene_census.csv` but can be pointed
# at any CGC snapshot (e.g., `/data/raw/cosmic/v100/Cosmic_CancerGeneCensus_v100_GRCh38.tsv`).
#
rule process_cgc:
  input:
    config.get("cosmic_cgc_path", "data/cancer_gene_census.csv")
  output:
    out_dir.joinpath("metadata/cgc_drivers.feather")
  script:
    "../scripts/process_cgc.py"

#
# Unified annotation overlay. Applies Bailey 2018 + COSMIC CGC + Sanchez-Vega 2018 pathway
# overlays in one pass to the raw cross-study feathers. Replaces the earlier chained
# annotate_drivers.py pattern (one rule per overlay per table).
#
# Canonical count-table output: `gene_cancer_study_annotated.feather`.
# Canonical ratio-table output: `gene_cancer_study_ratio_annotated.feather` (then chained
#                                 into annotate_ch for CH-aware stratification).
#
rule annotate_gene_cancer_table:
  input:
    out_dir.joinpath("summary/mut/table/gene_cancer_study.feather"),
    out_dir.joinpath("metadata/bailey2018_drivers.feather"),
    out_dir.joinpath("metadata/cgc_drivers.feather"),
    out_dir.joinpath("metadata/sanchez_vega_pathways.feather")
  output:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_annotated.feather")
  script:
    "../scripts/annotate.py"

rule annotate_gene_cancer_ratio_table:
  input:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio.feather"),
    out_dir.joinpath("metadata/bailey2018_drivers.feather"),
    out_dir.joinpath("metadata/cgc_drivers.feather"),
    out_dir.joinpath("metadata/sanchez_vega_pathways.feather")
  output:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio_overlay_annotated.feather")
  script:
    "../scripts/annotate.py"

#
# Clonal-hematopoiesis-aware annotation. Final canonical ratio output:
# `gene_cancer_study_ratio_annotated.feather` — carries Bailey + CGC + pathway overlays (from
# the upstream unified rule) AND the CH annotations. Closes audit findings F3 + F7; completes
# F4 canonical-output redirect for the ratio table.
#
# Adds `ch_priority_gene` flag (Bolton 2020 7-gene list) plus `mean_matched` / `mean_unmatched`
# stratified ratios computed over per-study columns partitioned by the `matched_normal_studies`
# config list.
#
# Config: populate `matched_normal_studies` in the run config with an explicit list of study IDs
# known to use patient-matched buffy-coat / normal sequencing. Studies omitted are treated as
# tumor-only. If the key is missing, all studies default to tumor-only and `mean_matched` is NaN.
#
rule annotate_ch_in_gene_cancer_ratio_table:
  input:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio_overlay_annotated.feather")
  output:
    out_dir.joinpath("summary/mut/table/gene_cancer_study_ratio_annotated.feather")
  script:
    "../scripts/annotate_ch.py"

#
# dNdScv per-study selection-based driver detection (Martincorena 2017).
#
# Requires R + dndscv (devtools::install_github("im3sanger/dndscv")). Optional rule —
# include explicit dndscv outputs in `rule all` only on configurations where R+dndscv are
# available. Uses GRCh37 RefCDS by default; for GRCh38 cohorts swap the refdb argument
# in the script.
#
rule run_dndscv:
  input:
    out_dir.joinpath("studies/{id}/mut/table/mut_filtered.feather")
  output:
    out_dir.joinpath("studies/{id}/mut/dndscv/genes.feather")
  script:
    "../scripts/run_dndscv.R"

#
# AACR Project GENIE per-panel coverage mask.
#
# Manual prerequisite: download a GENIE release from Synapse (Synapse account + GENIE Data
# Use Agreement required; v19.0-public release is at syn72382128). Place the release's
# `genomic_information.txt` at `data/genie/genomic_information.txt`.
#
# GENIE does NOT ship per-assay .bed files — coverage info is consolidated into a single
# `genomic_information.txt` per release (see code/scripts/process_genie_panel_coverage.py
# for the schema).
#
rule process_genie_panel_coverage:
  input:
    "data/genie/genomic_information.txt"
  output:
    out_dir.joinpath("metadata/genie_panel_coverage.feather")
  script:
    "../scripts/process_genie_panel_coverage.py"

#
# Panel callable-Mb registry (t081 subtask t092 / plan task 1).
#
# Aggregates per-panel callable coding length in Mb, with three provenance sources:
# bed_sum (from the GENIE coverage feather), config_override (from the
# `panel_callable_mb_override` config map — authoritative for MSK-IMPACT / FoundationOne
# / Tempus / Caris panel variants), and wes_default (for panels with neither BED coverage
# nor an override — used by e.g. WES / MC3 studies).
#
# Declared `localrules` so the rule runs locally (not cluster-scheduled) and its output
# persists via Snakemake's normal file-timestamp / DAG-invalidation logic; regenerated
# when the GENIE feather or the config override map changes. The tsv is a generated
# build artifact — not version-controlled.
#
# Reusable: also consumed by t070 (panel-version drift), t076 (NaN-vs-0 aware pooling),
# and t077 (GLMM-logit random-effects pooling as a study-level covariate / offset).
#
localrules: build_panel_callable_sizes

rule build_panel_callable_sizes:
  input:
    out_dir.joinpath("metadata/genie_panel_coverage.feather")
  output:
    out_dir.joinpath("metadata/panel_callable_mb.tsv")
  script:
    "../scripts/build_panel_callable_sizes.py"

