// h08-agnostic-covariate-association — proposition DAG for hypothesis h08.
// Outcome = signature exposure H (how much of a latent process); spectrum W (which process)
// kept separate because selection/immunoediting acts on H, not W. Arm-level H08a verdicts +
// the R1-R5 rivals are carried as edges; evidence lives in the paired edges.yaml.
// Adapted from models/h08-agnostic-signature-association.dot. Render: science dag render --dag h08-agnostic-covariate-association
digraph h08_agnostic_covariate_association {
  rankdir=LR;
  labelloc="t";
  label=<<b>h08 — agnostic covariate-signature association</b><br/><font point-size="9" color="#555"><i>auto-styled from edges.yaml — color=edge_status, width=|β|, style=HDI-crosses-zero-dashed, arrowhead=identification</i></font>>;
  node [shape=box, style="rounded,filled", fillcolor="#f0f0f0", fontsize=10];
  edge [fontsize=9];

  H            [label="Signature exposure H\n(OUTCOME: how much)", fillcolor="#fce8e6"];
  W            [label="Signature spectrum W\n(which process)", fillcolor="#e8f0fe"];

  uv_exposure  [label="UV exposure\n(anatomic-site proxy)"];
  smoking      [label="Tobacco exposure\n(pack-years / ever-smoker)"];
  apobec3      [label="APOBEC3A/B\nexpression"];
  mmr_pole     [label="MMR-loss / POLE\n(repair capacity)"];
  expr_module  [label="Expression module\n(immune / repair)"];

  tissue       [label="Tissue of origin", fillcolor="#fef7e0"];
  treatment    [label="Treatment history", fillcolor="#fef7e0"];
  study_assay  [label="Study / panel / assay", fillcolor="#fef7e0"];
  ancestry     [label="Ancestry / germline", fillcolor="#fef7e0"];
  selection    [label="Selection /\nimmunoediting", fillcolor="#e6f4ea"];

  uv_exposure -> H [color="#9e9e9e", penwidth=1.0, style="dotted", arrowhead=normal, label="[1] [✗]", fontsize=10, fontcolor="#9e9e9e"];
  smoking -> H [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[2]", fontsize=10, fontcolor="#1565c0"];
  apobec3 -> H [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[3]", fontsize=10, fontcolor="#2e7d32"];
  apobec3 -> W [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[4]", fontsize=10, fontcolor="#757575"];
  mmr_pole -> H [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[5]", fontsize=10, fontcolor="#c62828"];
  expr_module -> H [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[6]", fontsize=10, fontcolor="#c62828"];
  tissue -> H [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[7]", fontsize=10, fontcolor="#2e7d32"];
  tissue -> expr_module [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[8]", fontsize=10, fontcolor="#2e7d32"];
  treatment -> H [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[9]", fontsize=10, fontcolor="#757575"];
  study_assay -> H [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[10]", fontsize=10, fontcolor="#757575"];
  ancestry -> H [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[11]", fontsize=10, fontcolor="#757575"];
  selection -> H [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[12]", fontsize=10, fontcolor="#757575"];

  // --- Auto-footer legend (two-axis: edge_status + identification) ---
  subgraph cluster_auto_footer_legend {
    rank=sink;
    label="";
    color="#bdbdbd"; style="rounded"; margin=4;
    node [shape=plaintext, fontsize=9];
    footer_legend [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3" color="#bdbdbd">
      <tr><td bgcolor="#f5f5f5"><b>Auto legend</b></td><td bgcolor="#f5f5f5"><b>edge_status</b>: color / width / style</td><td bgcolor="#f5f5f5"><b>identification</b>: arrowhead</td></tr>
      <tr><td align="left">status</td><td align="left"><font color="#2e7d32">&#9473;&#9473;&#9654;</font> supported &nbsp; <font color="#1565c0">&#9472;&#9472;&#9654;</font> tentative &nbsp; <font color="#757575">&#8943;&#9654;</font> structural</td><td align="left"><font color="#2e7d32">&#9473;&#9473;&#9654;</font> normal: observational / structural / none</td></tr>
      <tr><td align="left"></td><td align="left"><font color="#c62828">&#9548;&#9548;&#9654;</font> unknown &nbsp; <font color="#9e9e9e">&#8943;&#9654;</font> [x] eliminated</td><td align="left"><font color="#2e7d32">&#9473;&#9473;&#9670;</font> interventional &nbsp; <font color="#2e7d32">&#9473;&#9473;&#8857;</font> longitudinal</td></tr>
    </table>>];
  }
}
