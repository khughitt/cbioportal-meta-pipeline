  rule build_panel_gene_sets:
    """Rule (1a): per-panel callable-gene feathers.

    Panel BED path resolves via config["select"]["panel_beds"][panel_id] when
    present, otherwise falls back to data/panels/{panel_id}.bed. Tests using
    the toy fixture override via the panel_beds config block."""
    input:
      bed = lambda wc: config.get("select", {}).get("panel_beds", {}).get(
        wc.panel_id, f"data/panels/{wc.panel_id}.bed"
      ),
      grch38 = lambda wc: config.get(
        "select_grch38_path", "data/grch38.tsv"
      )
    output:
      out_dir.joinpath("select/panel_gene_sets/{panel_id}.feather")
    log:
      out_dir.joinpath("logs/build_panel_gene_sets/{panel_id}.log")
    conda:
      "../envs/project-python.yml"
    script:
      "../scripts/build_panel_gene_sets.py"

  rule build_select_gene_universe:
    """Rule (1b): union of Bailey/CGC/Sanchez-Vega/optional custom genes.

    Source paths resolve via config["select"]["sources"][...] when present,
    otherwise fall back to the pipeline defaults under data/. Tests using the
    toy fixture override via the sources config block."""
    input:
      bailey = config.get("select", {}).get("sources", {}).get(
        "bailey", "data/bailey2018_table_s1.tsv"
