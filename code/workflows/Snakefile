# Prefer the panel-aware rule when both rules could produce the same three base files.
ruleorder: download_panel_study > download_study


def _convert_to_feather_inputs(wildcards):
    """Conditional input dict: matrix file appended for panel-bearing studies.

    Matches the static classification in config['panel_bearing_studies']; do not
    file-existence-test (would make the DAG non-deterministic).
    """
    base = {
        "mutations": data_dir.joinpath(f"{wildcards.id}/data_mutations.txt"),
        "samples":   data_dir.joinpath(f"{wildcards.id}/data_clinical_sample.txt"),
        "patients":  data_dir.joinpath(f"{wildcards.id}/data_clinical_patient.txt"),
    }
    if wildcards.id in config.get("panel_bearing_studies", []):
        base["panel_matrix"] = data_dir.joinpath(
            f"{wildcards.id}/data_gene_panel_matrix.txt"
        )
    return base


rule convert_to_feather:
  input:
    unpack(_convert_to_feather_inputs)
  output:
    out_dir.joinpath("studies/{id}/mut/table/mut.feather"),
    out_dir.joinpath("studies/{id}/metadata/samples.feather"),
    out_dir.joinpath("studies/{id}/metadata/patients.feather"),
    out_dir.joinpath("studies/{id}/metadata/study.feather"),
    out_dir.joinpath("studies/{id}/metadata/study_build.txt")
  script:
    "../scripts/convert_to_feather.py"


rule download_panel_study:
  """Variant of download_study for panel-bearing studies.

  The download script already extracts the full tarball, so data_gene_panel_matrix.txt
  lands on disk automatically. This rule declares it as an output so the DAG is aware
  of it and can wire it through _convert_to_feather_inputs.

  Outputs are wrapped with ``protected()`` so ``--forceall`` cannot silently wipe
  raw study data that would then have to be re-downloaded (cBioPortal occasionally
  returns HTTP 403 for re-requests). Use ``snakemake --unprotect`` to explicitly
  mark a file as overwritable if you intend to re-download.
  """
  output:
    protected(data_dir.joinpath("{id}/data_mutations.txt")),
    protected(data_dir.joinpath("{id}/data_clinical_sample.txt")),
    protected(data_dir.joinpath("{id}/data_clinical_patient.txt")),
    protected(data_dir.joinpath("{id}/data_gene_panel_matrix.txt")),
  wildcard_constraints:
    # Use `or` (not `.get(key, default)`) so an explicitly-empty list also
    # falls back to the sentinel — otherwise joining [] with | produces an
    # empty regex that matches ANY study id and silently captures WES studies.
    id="|".join(
      re.escape(s) for s in (config.get("panel_bearing_studies") or ["__never__"])
    )
  script:
    "../scripts/download_study.py"

rule download_study:
  """Outputs wrapped with ``protected()`` — see note on ``download_panel_study``."""
  output:
    protected(data_dir.joinpath("{id}/data_mutations.txt")),
    protected(data_dir.joinpath("{id}/data_clinical_sample.txt")),
    protected(data_dir.joinpath("{id}/data_clinical_patient.txt")),
  script:
    "../scripts/download_study.py"

#
# MC3 TCGA pan-cancer unified-MAF ingestion (Ellrott 2018). Produces a `tcga_mc3`
# pseudo-study that matches the existing per-study feather schema, so downstream rules
# consume it identically to cBioPortal studies.
#
# Manual prereqs:
#   - data/mc3.v0.2.8.PUBLIC.maf.gz       (GDC PASS release)
#   - data/tcga_case_to_project.tsv       (submitter_id -> TCGA project_id; fetched once
#                                           from the GDC API)
#
# Rule-order directive ensures this rule preempts the more-general convert_to_feather rule
# for the tcga_mc3 wildcard.
#
ruleorder: process_mc3 > convert_to_feather

rule process_mc3:
  input:
    mc3_maf = "data/mc3.v0.2.8.PUBLIC.maf.gz",
    case_to_project = "data/tcga_case_to_project.tsv"
  output:
    out_dir.joinpath("studies/tcga_mc3/mut/table/mut.feather"),
    out_dir.joinpath("studies/tcga_mc3/metadata/samples.feather"),
    out_dir.joinpath("studies/tcga_mc3/metadata/patients.feather"),
    out_dir.joinpath("studies/tcga_mc3/metadata/study.feather"),
    out_dir.joinpath("studies/tcga_mc3/metadata/study_build.txt")
  script:
    "../scripts/process_mc3.py"

#
# t078 SELECT pipeline — vendored upstream R package.
#
# Downloads the v1.6.4 source tarball from the public GitHub release and
# verifies its sha256 prefix. The artifact is committed to the repo so this
# rule normally never runs; it exists so the download recipe is reproducible
# (e.g., after `git clean -xdf data/external/` the rule restores the file
# byte-for-byte). To upgrade, bump SELECT_VERSION + SELECT_SHA256_PREFIX and
# re-run.
#
SELECT_VERSION = "1.6.4"
SELECT_SHA256_PREFIX = "1927b9880132"   # 12-char prefix

rule fetch_select_tarball:
  output:
    "data/external/select_v{version}.tar.gz".format(version=SELECT_VERSION)
  params:
    url=lambda wc: (
      f"https://github.com/CSOgroup/select/archive/refs/tags/v{SELECT_VERSION}.tar.gz"
    ),
    expected_sha256_prefix=SELECT_SHA256_PREFIX,
  shell:
    r"""
    mkdir -p $(dirname {output})
    curl -sSfL {params.url} -o {output}.tmp
    actual=$(sha256sum {output}.tmp | cut -c1-12)
    if [ "{params.expected_sha256_prefix}" != "<TBD-after-first-download>" ] && \
       [ "$actual" != "{params.expected_sha256_prefix}" ]; then
      echo "ERROR: sha256 mismatch for {output}" >&2
      echo "  expected prefix: {params.expected_sha256_prefix}" >&2
      echo "  actual prefix:   $actual" >&2
      rm -f {output}.tmp
      exit 1
    fi
    file {output}.tmp | grep -q "gzip compressed" || (
      echo "ERROR: download is not a gzip tarball (likely an HTML error page)" >&2
      rm -f {output}.tmp
      exit 1
    )
    mv {output}.tmp {output}
    """

