  # Pathway-aggregated cell uses tier sentinel "PA" with cohort fixed to "exclusive"
  # (the only biologically interpretable cohort for pathway aggregation -- see design
  # Section 4.4). Output goes to a sibling directory of the B/A inputs so the
  # wildcard schema does not collide.
  rule build_select_gam_pathway_aggregated:
    """Rule (2-PA): pathway-aggregated sibling GAM (B-tier-exclusive cohort)."""
