#
# h08 expression-module substrate (t198).
#
# Per-arm NMF module derivation for the h08 positive-control scan. Implements the frozen rule
# in `pre-registration:h08-positive-control` § Total Comparison Count, as clarified by
# Amendment 001 (realized unit log2(RSEM_V2+1) on per-study cBioPortal PanCanAtlas RNA-seq —
# TCGA PanCanAtlas ships RSEM, not TPM). For each arm stratum: restrict the study's RSEM matrix
# to MC3-overlapping samples, drop genes expressed in <10% of samples, keep the top-2,000 MAD
# genes, log2(RSEM+1), then NMF for K in {5..50} x 50 restarts and select the largest K before
# the Brunet cophenetic correlation drops below 0.90 (ties -> smaller K).
#
# LEAKAGE FIREWALL: the rule reads only the expression matrix and MC3 sample IDENTITY
# (tcga_mc3 samples.feather: sample_id + cancer_type, to enumerate arm membership) — never
# signature exposures, mutations, or covariates. K is therefore selected before, and
# independently of, any covariate<->signature association.
#
# Not in `rule all` — opt-in h08 surface. Target `all_h08_expression_modules` (or a single
# arm's module_selection.json). Arm->study map + random_seed come from the run config.
#
rule build_expression_nmf_modules:
  input:
    rsem = lambda wc: data_dir.joinpath(config["h08_arm_studies"][wc.arm], "data_mrna_seq_v2_rsem.txt"),
    mc3_samples = out_dir.joinpath("studies/tcga_mc3/metadata/samples.feather")
  output:
    modules = out_dir.joinpath("expression_modules/{arm}/nmf_gene_modules.feather"),
    loadings = out_dir.joinpath("expression_modules/{arm}/nmf_sample_loadings.feather"),
    cophenetic = out_dir.joinpath("expression_modules/{arm}/cophenetic_curve.feather"),
    selection = out_dir.joinpath("expression_modules/{arm}/module_selection.json")
  params:
    arm = lambda wc: wc.arm
  log:
    out_dir.joinpath("logs/build_expression_nmf_modules/{arm}.log")
  conda:
    "../envs/project-python.yml"
  script:
    "../scripts/build_expression_nmf_modules.py"

rule all_h08_expression_modules:
  input:
    expand(
      out_dir.joinpath("expression_modules/{arm}/module_selection.json"),
      arm=list(config.get("h08_arm_studies", {}).keys())
    )

#
# h08 within-tissue covariate<->signature association core (t199 — the H08a positive-control scan).
#
# WP0-WP3 of `doc/plans/2026-05-31-t199-h08-association-core.md`, reading the verdict locked in
# `pre-registration:h08-positive-control` (amendment-001). Opt-in surface; target
# `all_h08_association`. The four scripts are config-driven click CLIs (not the snakemake
# `script:` pattern), so they run under `shell:` with the active configfile ({h08_configfile}).
#
# WP0 — fetch + verify the PanCanAtlas clinical-with-followup table (the ONLY TCGA source of the
# Arm-B smoking covariates). Open-access GDC file UUID 0fc78496-...; the script downloads,
# stat/md5/column/LUAD+LUSC-non-missingness-verifies, exits non-zero on any failure, and writes a
# `.verification.json` sidecar. See `dataset:tcga-pancanatlas-clinical`.
#
rule fetch_pancanatlas_clinical:
  output:
    tsv = "data/pancanatlas_clinical_with_followup.tsv",
    sidecar = "data/pancanatlas_clinical_with_followup.tsv.verification.json"
  log:
    out_dir.joinpath("logs/fetch_pancanatlas_clinical.log")
  conda:
    "../envs/project-python.yml"
  shell:
    "python code/scripts/fetch_pancanatlas_clinical.py --dest {output.tsv} --sidecar {output.sidecar} > {log} 2>&1"

#
# WP1 — assemble + FREEZE the per-sample covariate table and the per-arm covariate-count
# denominator (the gate). Joins the t197 per-sample SBS exposures, the t198 NMF module loadings,
# and clinical / molecular covariates onto the 7 arm strata; emits `covariate_denominator.json`
# BEFORE any rank is computed. TMB comes from the independent clinical TMB_NONSYNONYMOUS field
# (burden firewall — H is not read for TMB). Clinical/RSEM inputs resolve under data_dir per
# `h08_arm_studies` (raw cBioPortal study downloads, like the NMF rule's rsem input).
#
rule build_h08_covariates:
  input:
    smoking = "data/pancanatlas_clinical_with_followup.tsv",
    exposures = out_dir.joinpath("studies/tcga_mc3/mut/signatures/restricted_assignment_per_sample.feather"),
    mutations = out_dir.joinpath("studies/tcga_mc3/mut/table/mut.feather"),
    loadings = expand(
      out_dir.joinpath("expression_modules/{arm}/nmf_sample_loadings.feather"),
      arm=list(config.get("h08_arm_studies", {}).keys())
    )
  output:
    covariates = out_dir.joinpath("association/h08_covariates.feather"),
    denominator = out_dir.joinpath("association/covariate_denominator.json")
  params:
    configfile = h08_configfile
  log:
    out_dir.joinpath("logs/build_h08_covariates.log")
  conda:
    "../envs/project-python.yml"
  shell:
    "python code/scripts/build_h08_covariates.py --config {params.configfile} --smoking {input.smoking} > {log} 2>&1"

#
# WP2 — the primary association scan. One adjusted within-tissue OLS per (covariate, signature,
# stratum); outcome = CLR coordinate of the target signature; ranking statistic = signed
# standardized coefficient; BH-FDR over the full grid. CLR is the FROZEN PRIMARY read. The script
# treats `covariate_denominator.json` as a read-only input, fails if it is missing, and logs its
# SHA256 into the grid meta so the gitignored freeze artifact has a durable fingerprint.
#
rule run_h08_association_scan:
  input:
    covariates = out_dir.joinpath("association/h08_covariates.feather"),
    denominator = out_dir.joinpath("association/covariate_denominator.json"),
    exposures = out_dir.joinpath("studies/tcga_mc3/mut/signatures/restricted_assignment_per_sample.feather")
  output:
    grid = out_dir.joinpath("association/h08_association_grid.feather"),
    meta = out_dir.joinpath("association/h08_association_grid.meta.json")
  params:
    configfile = h08_configfile
  log:
    out_dir.joinpath("logs/run_h08_association_scan.log")
  conda:
    "../envs/project-python.yml"
  shell:
    "python code/scripts/run_h08_association_scan.py --config {params.configfile} > {log} 2>&1"

#
# WP3 — pre-acceptance + registered sensitivity DIAGNOSTICS (not a path to a primary PASS).
# Permutation null (within-tissue shuffle, frozen seed, n=1000), absolute-burden re-rank
# (is_primary_gate=False), and the lung per-histology variant. Asserts the denominator SHA256
# equals the WP2 grid's frozen_denominator_manifest.sha256 and refuses to run on a mismatch, so
# the diagnostics are tied to the exact frozen base the gate was read under.
#
rule run_h08_sensitivity:
  input:
    covariates = out_dir.joinpath("association/h08_covariates.feather"),
    denominator = out_dir.joinpath("association/covariate_denominator.json"),
