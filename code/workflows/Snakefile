#
# Per-sample TMB computation (t093 / t081.2 / plan task 2).
#
# Computes per-sample mutation_count (protein-altering only), tmb, tmb_log10,
# panel_callable_mb, tmb_source, and propagates study_id as a first-class column
# (F3 fix). Emits a NEW file (samples_tmb.feather) so that existing consumers of
# samples.feather continue to see the original schema until they opt in.
#
rule compute_per_sample_tmb:
  input:
    muts = out_dir.joinpath("studies/{id}/mut/table/mut_filtered.feather"),
    samples = out_dir.joinpath("studies/{id}/metadata/samples.feather"),
    panels = out_dir.joinpath("metadata/panel_callable_mb.tsv")
  output:
    out_dir.joinpath("studies/{id}/metadata/samples_tmb.feather")
  script:
    "../scripts/compute_per_sample_tmb.py"

#
# POLE / POLD1 hotspot detector (t094 / t081.3 / plan task 3).
#
# Independent biological signal for ultra-hypermutation: per-sample boolean flags
# pole_hotspot_detected and pold1_hotspot_detected, based on exact uppercase amino-
# acid matching against the canonical 8-entry POLE and 6-entry POLD1 hotspot lists
# (Campbell 2017, Rayner 2016, Ma 2018). Consumes raw mut.feather (not the gene-
# coverage-filtered version) so that POLE/POLD1 mutations are not accidentally
# filtered out before detection. Output only lists samples with at least one
# mutation in POLE or POLD1; the composite step (t097) left-joins this onto the
# per-study samples table and treats NaN as False.
#
rule detect_polymerase_hotspots:
  input:
    out_dir.joinpath("studies/{id}/mut/table/mut.feather")
  output:
    out_dir.joinpath("studies/{id}/metadata/sample_polymerase_hotspots.feather")
  script:
    "../scripts/detect_polymerase_hotspots.py"

#
# Combine per-study samples_tmb + polymerase hotspot flags (t096 / plan task 5
# prereq). Produces the single cross-study table consumed by the GMM fit and by
# the composite hypermutator flag (t097).
#
rule combine_samples_tmb:
  input:
    samples_tmb = expand(out_dir.joinpath("studies/{id}/metadata/samples_tmb.feather"), id=ids),
    pole_hotspots = expand(out_dir.joinpath("studies/{id}/metadata/sample_polymerase_hotspots.feather"), id=ids)
  output:
    out_dir.joinpath("metadata/samples_tmb_combined.feather")
  script:
    "../scripts/combine_samples_tmb.py"

#
# Per-cancer-type TMB GMM fit (t096 / t081.5 / plan task 5).
#
# Fits a 2-component GaussianMixture on log10 TMB per cancer type; selects
# 2-component only when delta-BIC > 10 AND Hartigan dip p < 0.1 AND
# n_samples >= gmm_min_samples. Otherwise falls through to single_mode /
# not_bimodal / insufficient_data. The insufficient_data branch applies a
# 10 * median TMB fallback. Always emits tmb_zscore_within_cancer as a
# fallback signal for the composite flag (t097 rows 6 / 7).
#
# Reproducibility covenant: random_state is pinned to config['random_seed']
# (default 0) for every sklearn.mixture.GaussianMixture call. See the file
# docstring and doc/plans/2026-04-13-t081-hypermutator-annotation-plan-review.md
# finding #1.
#
rule fit_per_cancer_tmb_gmm:
  input:
    samples_tmb_combined = out_dir.joinpath("metadata/samples_tmb_combined.feather")
  output:
    per_cancer_fits = out_dir.joinpath("metadata/per_cancer_gmm_fits.feather"),
    samples_flagged = out_dir.joinpath("metadata/samples_gmm_flagged.feather")
  script:
    "../scripts/fit_per_cancer_tmb_gmm.py"

#
# Composite hypermutation score + final is_hypermutator flag (t097 / t081.6 /
# plan task 6). Applies the canonical 8-row decision table (F4 fix) and emits
# the three parallel t089 dual flags (absolute >=10 mut/Mb, ultra >=100 mut/Mb,
# relative top-20% per histology). This is the load-bearing output for the
# hypermutator-aware cross-study aggregation step (t098).
#
rule annotate_hypermutators:
  input:
    samples_tmb_combined = out_dir.joinpath("metadata/samples_tmb_combined.feather"),
    per_cancer_fits = out_dir.joinpath("metadata/per_cancer_gmm_fits.feather"),
    samples_flagged = out_dir.joinpath("metadata/samples_gmm_flagged.feather")
  output:
    out_dir.joinpath("metadata/samples_annotated.feather")
  script:
    "../scripts/annotate_hypermutators.py"

rule check_gene_coverage:
  input:
    expand(out_dir.joinpath("studies/{id}/mut/table/mut.feather"), id=ids),
  output:
    out_dir.joinpath("metadata/gene_counts.feather")
  script:
    "../scripts/check_gene_coverage.py"

