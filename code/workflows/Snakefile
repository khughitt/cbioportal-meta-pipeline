    smoking_counts = out_dir.joinpath("association/diagnostics/h08_smoking_label_counts.feather"),
    burden = out_dir.joinpath("association/diagnostics/h08_burden_conditioning.feather"),
    proliferation = out_dir.joinpath("association/diagnostics/h08_apobec_proliferation.feather"),
    meta = out_dir.joinpath("association/diagnostics/h08_within_tissue_diagnostics.meta.json")
  params:
    configfile = h08_configfile
  log:
    out_dir.joinpath("logs/diagnose_h08_within_tissue.log")
  conda:
    "../envs/project-python.yml"
  shell:
    "python code/scripts/diagnose_h08_within_tissue.py --config {params.configfile} --smoking {input.smoking} > {log} 2>&1"

