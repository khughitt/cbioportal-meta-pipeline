#
# t078 SELECT co-occurrence / mutual-exclusivity layer (opt-in via config["select"]
# ["enabled"]). See doc/plans/2026-04-25-t078-select-cooccurrence-design.md.
#

select_enabled = config.get("select", {}).get("enabled", False)

def _panels_for_cancer_study(cancer_type: str, study: str | None = None) -> list[str]:
  """Panels needed for one cell, looked up by cancer_type and (optional) study.

  For A-tier cells: pass the named study so only that study's panel(s) are returned.
  For B-tier and PA cells: pass study=None to get every panel that any sample of
  the cancer type uses.

  Reads sample_panel_map.feather + samples_annotated.feather lazily; rules using
  this helper must depend on those files existing before the lambda is evaluated.
  """
  spm = pd.read_feather(out_dir.joinpath("metadata/sample_panel_map.feather"))
  samples = pd.read_feather(out_dir.joinpath("metadata/samples_annotated.feather"))
  rel = samples.merge(spm, on=["study_id", "sample_id"], how="inner")
  rel = rel[rel["cancer_type"] == cancer_type]
  if study is not None:
    rel = rel[rel["study_id"] == study]
  return sorted(rel["panel_id"].dropna().unique().tolist())


def _panels_for_cell(config: dict, wildcards) -> list[str]:
  """Wildcards-shape adapter for build_select_gam (B/A) rule."""
  study = wildcards.study if wildcards.tier == "A" else None
  return _panels_for_cancer_study(wildcards.cancer_type, study)


def _all_per_cell_paths(config: dict) -> list[str]:
  """Enumerate every per-cell pair_stats.feather Snakemake should expand to.

  Reads samples_annotated.feather lazily. The aggregate rule's `input:` lambda
  must wait for that file before this is invoked at DAG-resolution time.
  """
  samples = pd.read_feather(out_dir.joinpath("metadata/samples_annotated.feather"))
  cancer_types = sorted(samples["cancer_type"].dropna().unique())
  studies = sorted(samples["study_id"].dropna().unique())
  paths: list[str] = []
  for ct in cancer_types:
    for cohort in ("inclusive", "exclusive"):
      paths.append(str(out_dir.joinpath(
        f"select/per_cell/{ct}/B/_/{cohort}/pair_stats.feather"
      )))
      for st in studies:
        paths.append(str(out_dir.joinpath(
          f"select/per_cell/{ct}/A/{st}/{cohort}/pair_stats.feather"
        )))
  return paths


