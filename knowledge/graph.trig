    <http://example.org/project/interpretation/0039-t215-neural-gene-reproduction-gate> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/paper/lu2026>,
            <http://example.org/project/source-snapshot/6f09389d1bc00e55>,
            <http://example.org/project/source-snapshot/d747bf79cef37b08> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t215: neural-gene mutation-enrichment partially reproduces — real top-1% non-driver enrichment, but a large-locus/CFS class effect, not a neural-specific or protein-length one" ;
        skos:related <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/question/0032-neural-gene-length-null>,
            <http://example.org/project/question/0033-neural-enrichment-cns-exclusion>,
            <http://example.org/project/question/0035-label-free-neural-gene-definition>,
            <http://example.org/project/task/t215>,
            <http://example.org/project/task/t216>,
            <http://example.org/project/task/t217>,
            <http://example.org/project/task/t221> ;
        schema:identifier "interpretation:0039-t215-neural-gene-reproduction-gate" .
    <http://example.org/project/interpretation/0040-t216-label-free-neural-score> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/source-snapshot/0b346d92f43a79ba> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t216: a reproducible label-free neural score confirms the candidates are genuinely CNS-specific — but the score cannot separate neural effectors from large CFS loci (AUC 0.47), so high neural expression does not rescue the candidate enrichment from the genomic-span confound" ;
        skos:related <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/interpretation/0039-t215-neural-gene-reproduction-gate>,
            <http://example.org/project/interpretation/0041-t217-genomic-span-cfs-null>,
            <http://example.org/project/question/0035-label-free-neural-gene-definition>,
            <http://example.org/project/task/t216>,
            <http://example.org/project/task/t218> ;
        schema:identifier "interpretation:0040-t216-label-free-neural-score" .
    <http://example.org/project/interpretation/0041-t217-genomic-span-cfs-null> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/source-snapshot/d2f6cf9b705db6f0> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t217: neural-gene mutation enrichment is a genomic-span / common-fragile-site artifact — it survives a coding-length null but dissolves under genomic-span normalization; a small residual remains only in the panel-heavy full config (panel ascertainment, not biology)" ;
        skos:related <http://example.org/project/hypothesis/0003-gene-length-confounds-literature-attention>,
            <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/interpretation/0039-t215-neural-gene-reproduction-gate>,
            <http://example.org/project/question/0016-panel-induced-ascertainment>,
            <http://example.org/project/question/0032-neural-gene-length-null>,
            <http://example.org/project/task/t217>,
            <http://example.org/project/task/t218>,
            <http://example.org/project/task/t221> ;
        schema:identifier "interpretation:0041-t217-genomic-span-cfs-null" .
    <http://example.org/project/interpretation/0042-t218-cns-exclusion-wes-panel> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/source-snapshot/9878b592cecdd9e8> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t218: the candidate mutation enrichment is not CNS-driven and the t217 residual is not panel ascertainment — it is one cohort's all-region (98.5%-intronic) mutation table tiling the candidates' multi-Mb loci; removing it returns them to the genomic-span null, closing the candidate-set mutational-count thread of the neural-gene artifact hypothesis" ;
        skos:related <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/interpretation/0040-t216-label-free-neural-score>,
            <http://example.org/project/interpretation/0041-t217-genomic-span-cfs-null>,
            <http://example.org/project/question/0016-panel-induced-ascertainment>,
            <http://example.org/project/question/0033-neural-enrichment-cns-exclusion>,
            <http://example.org/project/task/t218>,
            <http://example.org/project/task/t221> ;
        schema:identifier "interpretation:0042-t218-cns-exclusion-wes-panel" .
    <http://example.org/project/interpretation/0043-t221a-sample-level-hypermutator-exclusion> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/source-snapshot/2fd03fb146b1d476> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t221(a): the full-WES neural-gene residual is NOT a hypermutator artifact — a sample-level exclusion across all 91 WES studies (326 hypermutator samples, 1.15M variant rows dropped) leaves the genomic-span residual exactly where it was (span-matched p 0.002 -> 0.002)" ;
        skos:related <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/interpretation/0041-t217-genomic-span-cfs-null>,
            <http://example.org/project/interpretation/0042-t218-cns-exclusion-wes-panel>,
            <http://example.org/project/question/0032-neural-gene-length-null>,
            <http://example.org/project/task/t221> ;
        schema:identifier "interpretation:0043-t221a-sample-level-hypermutator-exclusion" .
    <http://example.org/project/interpretation/0044-t221b-standing-controls-panel> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/source-snapshot/b4d40dd4b59640d1> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t221(b): four standing controls lock down the candidate-set verdict — the residual is entirely an all-region call-set artifact (6 studies; gone in 84 exonic-clean ones), the candidates are statistically indistinguishable from known CFS genes, germline (dbSNP) leak is not the driver, and no label-free neural set reproduces the enrichment" ;
        skos:related <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/interpretation/0040-t216-label-free-neural-score>,
            <http://example.org/project/interpretation/0041-t217-genomic-span-cfs-null>,
            <http://example.org/project/interpretation/0042-t218-cns-exclusion-wes-panel>,
            <http://example.org/project/interpretation/0043-t221a-sample-level-hypermutator-exclusion>,
            <http://example.org/project/question/0016-panel-induced-ascertainment>,
            <http://example.org/project/question/0032-neural-gene-length-null>,
            <http://example.org/project/task/t221> ;
        schema:identifier "interpretation:0044-t221b-standing-controls-panel" .
    <http://example.org/project/interpretation/0045-t221d-matched-normal-split> sci:freshnessState "needs-review" ;
        sci:profile "core" ;
        sci:projectStatus "active" ;
        sci:scope "project" ;
        sci:triggeredBy <http://example.org/project/source-snapshot/3413bcdd9510c934> ;
        sci:upstreamChangeAt "2026-06-28"^^<http://www.w3.org/2001/XMLSchema#date> ;
        a sci:Interpretation ;
        skos:prefLabel "t221(d): a true study-level matched- vs unmatched-normal split confirms germline leak is not the candidate driver — within call-set-region stratum the residual is identical across normal status (all-region matched p 0.0000 vs unmatched 0.0006; both exonic arms null), and the biggest single residual-carrier (pog570) is matched-normal" ;
        skos:related <http://example.org/project/hypothesis/0012-neural-gene-enrichment-length-histology-artifact>,
            <http://example.org/project/interpretation/0041-t217-genomic-span-cfs-null>,
            <http://example.org/project/interpretation/0042-t218-cns-exclusion-wes-panel>,
